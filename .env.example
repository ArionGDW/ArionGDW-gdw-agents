# Read-only path to the GDW mini-program repository.
GDW_PRODUCT_REPO=/Users/shiyao/Downloads/网球APP开发

# Default uses data/mock/feishu-docs.json. Live Feishu calls are intentionally not enabled in v0.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_ACCESS_TOKEN=
FEISHU_MOCK_FIXTURE=data/mock/feishu-docs.json
# Comma-separated or newline-separated authoritative Feishu Wiki/docx URLs.
# When set, advisor:simulate uses these live documents by default.
FEISHU_CONTEXT_URLS=
FEISHU_REFERENCE_URLS=
FEISHU_WRITE_ENABLED=false

# Feishu event callback service.
FEISHU_EVENT_PORT=8787
FEISHU_VERIFICATION_TOKEN=

# Optional channel / meeting configuration placeholders.
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
QCLAW_WEBHOOK_URL=
TENCENT_MEETING_APP_ID=
TENCENT_MEETING_SECRET=
